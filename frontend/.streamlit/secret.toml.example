# EXAMPLE SECRETS FILE - DO NOT COMMIT REAL VALUES
# Copy this to secret.toml and fill in your actual values
# The secret.toml file is gitignored and will NOT be committed

[backend]
url = "http://localhost:8000"  # Local dev or https://your-railway-url.railway.app

[supabase]
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_ANON_KEY = "your_anon_key_here"

[google_oauth]
redirect_uri = "http://localhost:8501"  # Change to your deployed frontend URL in production
client_id = "your_google_client_id"
client_secret = "your_google_client_secret"
